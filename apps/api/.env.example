# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# WARNING: never run that command again after the first time — it will
# overwrite your real keys with blanks.
#
# This file is committed to git (no secrets). Your .env is git-ignored.

GOOGLE_API_KEY=
BROWSER_USE_API_KEY=

# Comma-separated browser origins allowed to call the API (needed if the UI uses
# NEXT_PUBLIC_DIRECT_API_ORIGIN for SSE, or any direct fetch from the browser).
# Example: https://qa.yourdomain.com,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Persistent storage for SQLite + artifacts (set on Docker / PaaS with a volume).
# DATA_DIR=/app/data
